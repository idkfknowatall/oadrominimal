// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  discordId     String   @unique @map("discord_id") @db.VarChar(20)
  username      String   @db.VarChar(100)
  discriminator String?  @db.VarChar(10)
  avatar        String?  @db.VarChar(255)
  isAdmin       Boolean  @default(false) @map("is_admin")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  votes            Vote[]
  dislikeFeedback  DislikeFeedback[] @relation("UserFeedback")
  reviewedFeedback DislikeFeedback[] @relation("ReviewedBy")

  @@index([discordId])
  @@map("users")
}

model Song {
  id           Int      @id @default(autoincrement())
  songId       String   @unique @map("song_id") @db.VarChar(255)
  title        String   @db.VarChar(500)
  artist       String   @db.VarChar(500)
  albumArt     String?  @map("album_art") @db.Text
  genre        String?  @db.VarChar(100)
  duration     Int?
  likeCount    Int      @default(0) @map("like_count")
  dislikeCount Int      @default(0) @map("dislike_count")
  totalVotes   Int      @default(0) @map("total_votes")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  votes           Vote[]
  dislikeFeedback DislikeFeedback[]

  @@index([songId])
  @@index([likeCount, dislikeCount])
  @@index([totalVotes])
  @@map("songs")
}

model Vote {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  songId    Int      @map("song_id")
  voteType  VoteType @map("vote_type")
  timestamp DateTime @default(now())

  // Relations
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  song            Song              @relation(fields: [songId], references: [id], onDelete: Cascade)
  dislikeFeedback DislikeFeedback[]

  @@unique([userId, songId])
  @@index([userId, songId])
  @@index([songId, voteType])
  @@index([timestamp])
  @@map("votes")
}

model DislikeFeedback {
  id         Int       @id @default(autoincrement())
  voteId     Int       @map("vote_id")
  userId     Int       @map("user_id")
  songId     Int       @map("song_id")
  reason     String    @db.Text
  category   String?   @db.VarChar(50)
  isReviewed Boolean   @default(false) @map("is_reviewed")
  reviewedBy Int?      @map("reviewed_by")
  reviewedAt DateTime? @map("reviewed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  vote     Vote  @relation(fields: [voteId], references: [id], onDelete: Cascade)
  user     User  @relation("UserFeedback", fields: [userId], references: [id], onDelete: Cascade)
  song     Song  @relation(fields: [songId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReviewedBy", fields: [reviewedBy], references: [id])

  @@index([isReviewed])
  @@index([songId])
  @@index([createdAt])
  @@map("dislike_feedback")
}

enum VoteType {
  like
  dislike
}
